<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.ramm_fr.OpenBrowser</id>
  <name>OpenBrowser</name>
  <summary>A fast, private, open-source web browser for Linux</summary>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <description>
    <p>OpenBrowser is a native Linux web browser built with GTK4, libadwaita, and WebKitGTK.</p>
    <p>Features include vertical tabs, a download manager, bookmarks, history, password management, privacy controls, and developer tools.</p>
  </description>
  <launchable type="desktop-id">io.github.ramm_fr.OpenBrowser.desktop</launchable>
